# SPDX-License-Identifier: Apache-2.0
# 99-Operations/config.env.example — copy to config.env (gitignored) and fill in
# your personal values:
#     cp 99-Operations/config.env.example 99-Operations/config.env
#
# The live config.env is PRIVATE (gitignored). It sources the framework defaults first,
# then applies your personal/machine overrides below. Every existing `source config.env`
# therefore still works and gets defaults + overrides.

# Load framework defaults (public, tracked). KEEP THIS LINE.
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/config.defaults.env"

# --- Personal / machine overrides (private) ---
export VAULT_ROOT="${HOME}/Vault"               # set your absolute vault path
export PATH="$VAULT_ROOT/.venv/bin:$PATH"       # put the vault venv on PATH (harmless if none)
# Pillars — uncomment to pin your own. RECOMMENDED even if you keep the default set:
# unpinned, you inherit the framework's EXAMPLE default, so an update to the public
# config.defaults.env would silently re-pillar your vault.
# Each pillar is ONE lowercase kebab slug; whitespace separates pillars (ADR-0029).
# A multi-word pillar is one hyphenated token: "mental-health financial" = 2 pillars,
# "mental health financial" = 3. Display names alias at the link instead:
# [[mental-health-domain-index|Mental Health]]
# export PILLARS="mental health financial social technology calling"   # 6 pillars
